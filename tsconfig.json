{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "nodenext",
    "types": ["node"],
    "target": "ES2023",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test", "prisma"]
}